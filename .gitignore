# 配置文件（含 API 密钥，不要上传）
ov.conf

# Python 虚拟环境
.venv/

# OpenViking 运行时数据（向量库、会话记忆等）
openviking_workspace/

# 运行日志
*.log
service.log
research.latest.log

# 上传的 agent 文件（本地运行时产物）
uploaded_agents/

# 状态缓存（记录已上传路径，含本机绝对路径）
service_state.json

# macOS 系统文件
.DS_Store

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# IDE
.vscode/settings.json
